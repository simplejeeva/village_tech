# Copy this file to .env and fill the values.
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
# Comma-separated origin URLs that are allowed to POST forms (CSRF protection).
# Include your Vercel preview + production URLs here in production.
DJANGO_CSRF_TRUSTED_ORIGINS=https://*.vercel.app,http://localhost:8000,http://127.0.0.1:8000
# Password for the private customer dashboard at /customer/
DASHBOARD_PASSWORD=jeeva9600
# Production: Neon Postgres connection string. Leave empty locally to use SQLite.
# Example: postgresql://user:pass@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
